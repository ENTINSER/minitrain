{
    "// 1": "Top-level training batch settings. Update placeholders before launching multi-GPU training.",
    "train_batch_size": "auto",
    "train_micro_batch_size_per_gpu": "auto",
    "gradient_accumulation_steps": "auto",

    "// 2": "AdamW optimizer. Hyper-parameters are usually overridden by TrainingArguments.",
    "optimizer": {
        "type": "AdamW",
        "params": {
            "lr": "auto",
            "betas": [0.9, 0.999],
            "eps": 1e-8,
            "weight_decay": "auto"
        }
    },

    "// 3": "Warmup learning-rate scheduler. The warmup period is controlled by TrainingArguments.",
    "scheduler": {
        "type": "WarmupLR",
        "params": {
            "warmup_min_lr": 0,
            "warmup_max_lr": "auto",
            "warmup_num_steps": "auto"
        }
    },

    "// 4": "ZeRO stage 3 with CPU offload for optimizer state, gradients and parameters.",
    "zero_optimization": {
        "stage": 3,
        "offload_optimizer": {
            "device": "cpu",
            "pin_memory": true
        },
        "offload_param": {
            "device": "cpu",
            "pin_memory": true
        },
        "overlap_comm": true,
        "contiguous_gradients": true,
        "sub_group_size": 1e9,
        "reduce_bucket_size": "auto",
        "stage3_prefetch_bucket_size": "auto",
        "stage3_param_persistence_threshold": "auto",
        "stage3_max_live_parameters": 1e9,
        "stage3_max_reuse_distance": 1e9,
        "stage3_gather_16bit_weights_on_model_save": true
    },

    "// 5": "Mixed precision. Enable bf16 on Ampere-or-newer GPUs; set both to false for CPU/Mac safety.",
    "bf16": {
        "enabled": false
    },
    "fp16": {
        "enabled": false
    },

    "// 6": "Gradient clipping and logging.",
    "gradient_clipping": "auto",
    "steps_per_print": 10,

    "// 7": "Wall-clock timeout for a single training run (seconds). 0 means no timeout.",
    "wall_clock_breakdown": false
}
